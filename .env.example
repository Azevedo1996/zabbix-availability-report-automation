# =========================
# ZABBIX
# =========================
ZABBIX_REPORT_URL=https://zabbix.example.com/zabbix/report2.php
ZABBIX_USER=your_zabbix_username
# If your password contains "$", escape it as "$$" when using Docker Compose.
# Example: abc$def must be written as abc$$def
ZABBIX_PASSWORD=your_zabbix_password

# =========================
# REPORT FILTERS
# =========================
# Comma-separated list of host groups to collect.
REPORT_GROUPS=Network Devices,VMware Hosts,Windows Servers,Linux Servers
REPORT_MODE=1

# Optional but recommended: use numeric host group IDs to avoid UI selection issues.
# For group names, convert spaces and " - " to underscores.
# Example: "Network Devices" -> GROUP_ID_Network_Devices
GROUP_ID_Network_Devices=123
GROUP_ID_VMware_Hosts=124
GROUP_ID_Windows_Servers=125
GROUP_ID_Linux_Servers=126

# Zabbix template/trigger IDs used by report2.php.
# Find these values in the generated Zabbix report URL.
TEMPLATE_ID=00000
TRIGGER_ID=00000

# =========================
# EXECUTION
# =========================
HEADLESS=true
DEBUG_SCREENSHOTS=true
TZ=America/Sao_Paulo

# =========================
# PDF PRINT SETTINGS
# =========================
# A2 landscape works well for large reports with 50 rows per Zabbix page.
PDF_SCALE=0.95
PRINT_FONT_SIZE=8.6
PRINT_ROW_HEIGHT=15
HIDE_GRAPH_COLUMN=true

# =========================
# EMAIL PLACEHOLDERS
# =========================
# Current public version generates a .eml file only. It does not send automatically.
MAIL_MODE=none
MAIL_FROM=sender@example.com
MAIL_TO=recipient@example.com
MAIL_CC=
MAIL_SUBJECT_PREFIX=Zabbix Availability Report
